# GEMINI_API_KEY: Used as a fallback for plant identification when Qianfan
# credentials are not configured. AI Studio may inject this at runtime from
# user secrets; other production hosts need it set in their environment.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# API_KEY and APP_ID: Preferred plant identification provider via Qianfan.
API_KEY="YOUR_QIANFAN_API_KEY"
APP_ID="YOUR_QIANFAN_APP_ID"

# QIANFAN_MODEL: Optional vision model for plant identification.
# qwen3-vl-235b-a22b-instruct is available on the Qianfan account used during local testing.
QIANFAN_MODEL="qwen3-vl-235b-a22b-instruct"

# ELEVENLABS_API_KEY: Required for real ElevenLabs narrated AI video guides.
# Without this key the app falls back to the browser voice and does not call ElevenLabs.
# The default voice is Rachel, a premade female ElevenLabs voice.
ELEVENLABS_API_KEY="YOUR_ELEVENLABS_API_KEY"
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
ELEVENLABS_MODEL="eleven_multilingual_v2"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── Tencent Cloud COS (image & JSON output storage) ──────────────────────────
# Create a bucket at https://console.cloud.tencent.com/cos and fill in below.
#
# COS_SECRET_ID / COS_SECRET_KEY: sub-account key with cos:PutObject permission.
#   Generate at https://console.cloud.tencent.com/cam/capi
COS_SECRET_ID="YOUR_COS_SECRET_ID"
COS_SECRET_KEY="YOUR_COS_SECRET_KEY"

# COS_BUCKET: bucket name including the APPID suffix, e.g. rooted-1234567890
COS_BUCKET="YOUR_BUCKET_NAME"

# COS_REGION: bucket region, e.g. ap-guangzhou, ap-shanghai, ap-beijing
COS_REGION="ap-guangzhou"

# COS_DOMAIN (optional): custom or CDN domain mapped to the bucket.
# Leave blank to use the default COS endpoint.
# COS_DOMAIN="your-cdn.example.com"
